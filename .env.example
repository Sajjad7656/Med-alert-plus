# MediAlert+ Environment Variables
# Copy this file to .env.local and update with your actual values

# Application Configuration
VITE_APP_NAME=MediAlert+
VITE_APP_URL=https://medialert.com
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_URL=https://api.medialert.com
VITE_API_VERSION=v1
VITE_API_TIMEOUT=10000

# Contact Information
VITE_CONTACT_PHONE=1-800-555-1234
VITE_CONTACT_EMAIL=contact@medialert.com
VITE_CONTACT_ADDRESS=100 Health Plaza, Boston, MA 02118

# Analytics and Tracking
VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
VITE_SENTRY_DSN=your-sentry-dsn

# Third-party Services
VITE_CHAT_WIDGET_API_KEY=your-chat-api-key
VITE_MAP_API_KEY=your-map-api-key
VITE_WEATHER_API_KEY=your-weather-api-key

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHAT_SUPPORT=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Development Configuration
VITE_DEV_SERVER_PORT=8082
VITE_DEV_SERVER_HOST=localhost
VITE_ENABLE_SOURCE_MAPS=true

# Production Configuration
VITE_BUILD_OUTPUT_DIR=dist
VITE_BUILD_SOURCE_MAP=false
VITE_BUILD_MINIFY=true

# Security
VITE_CSP_NONCE=random-nonce-value
VITE_SESSION_SECRET=your-session-secret
VITE_JWT_SECRET=your-jwt-secret

# Business Configuration
VITE_CURRENCY=USD
VITE_TIMEZONE=America/New_York
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,es,fr

# Emergency Services
VITE_EMERGENCY_PHONE=911
VITE_EMERGENCY_SMS_ENABLED=true
VITE_EMERGENCY_EMAIL_ENABLED=true

# Monitoring and Health Checks
VITE_HEALTH_CHECK_ENDPOINT=/health
VITE_METRICS_ENDPOINT=/metrics
VITE_LOG_LEVEL=info
